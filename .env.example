# =============================================================
# Syntia MVP – Variables de entorno requeridas
# =============================================================
# Copia este archivo como .env y rellena los valores reales.
# El archivo .env NUNCA se sube a git (está en .gitignore).
# =============================================================

# Base de datos PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/syntia_db
DB_USER=syntia
DB_PASSWORD=tu_password_aqui

# JWT (mínimo 32 caracteres)
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_seguro
JWT_EXPIRATION=86400000

# OpenAI (obtén tu key en https://platform.openai.com/api-keys)
# Si está vacía el sistema usa el motor rule-based automáticamente
OPENAI_API_KEY=sk-proj-...

# Admin inicial (se crea automáticamente al arrancar si no existe)
ADMIN_EMAIL=admin@syntia.com
ADMIN_PASSWORD=cambia_esto_por_una_password_segura

# Email (Google SMTP – usa una "App Password" de Google, no tu password normal)
# https://myaccount.google.com/apppasswords
MAIL_USERNAME=syntialicante@gmail.com
MAIL_PASSWORD=tu_app_password_de_google

# Google OAuth2 (obtén el Client ID en https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com

# URL del frontend (para enlaces en emails de verificacion)
APP_FRONTEND_URL=http://localhost:3000

